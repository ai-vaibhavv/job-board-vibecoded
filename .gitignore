# Secrets — never commit these
.env
*.env
!.env.example

# Data / runtime state
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.log
.cache/

# Local configuration (copies of the examples)
config/settings.yaml
config/sources.yaml
config/profile.yaml

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local tool state (machine-specific permission allowlists, not project config)
.claude/settings.local.json
