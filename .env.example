# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# `.env` is listed in .gitignore — never commit it, and never paste your real
# webhook URL or API keys into issues, chats, or screenshots. Anyone who has the
# webhook URL can post messages to your Discord channel.

# ---------------------------------------------------------------------------
# REQUIRED — Discord webhook
# ---------------------------------------------------------------------------
# Discord -> Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
# Looks like: https://discord.com/api/webhooks/123456789012345678/AbC-dEf...
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# OPTIONAL — search-engine discovery (used by the `search_api` source)
# ---------------------------------------------------------------------------
# The application runs fine WITHOUT any of these: RSS, HTML and JSON sources
# keep working. A key is only needed for search-engine discovery queries such as
# `site:linkedin.com/jobs/view "research assistant" Germany`.
#
# Set SEARCH_API_PROVIDER to one of: tavily | brave | bing | google_cse | serpapi
# and provide the matching key below. Leave SEARCH_API_PROVIDER empty to disable.
#
# RECOMMENDED: tavily — free tier (1,000 credits/month), NO credit card needed.
#   1. Sign up at https://app.tavily.com/
#   2. Copy your API key (it starts with `tvly-`)
#   3. Set:  SEARCH_API_PROVIDER=tavily
#            SEARCH_API_KEY=tvly-your-key-here
#
# Note: Brave's "free" tier still asks for a credit card at signup.
SEARCH_API_PROVIDER=
SEARCH_API_KEY=

# Only required when SEARCH_API_PROVIDER=google_cse
# (the Programmable Search Engine ID, sometimes called `cx`)
GOOGLE_CSE_ID=

# ---------------------------------------------------------------------------
# OPTIONAL — LLM relevance assessment (strongly recommended)
# ---------------------------------------------------------------------------
# An LLM reads each job and judges it far better than keyword matching can. This
# project uses your own self-hosted model (e.g. Qwen2.5-7B on a free Colab GPU
# via Ollama). With none configured, the app falls back to keyword scoring and
# works exactly as before.
#
# The endpoint URL goes in config/settings.yaml as `llm.colab_base_url` (it is
# not a secret and it changes every session). The token below is only needed if
# you put your server behind an API key; Ollama needs none, so leave it blank.
# Full setup: docs/colab-model.md
COLAB_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Apify, for LinkedIn POSTS
# ---------------------------------------------------------------------------
# A lot of German lab hiring is advertised as an ordinary LinkedIn post rather
# than in the jobs section, and a web search cannot reach the post body — which
# is where the link and the email are. This is how those get in.
#
# Free plan: $5/month, no credit card. The actor charges $5 per 1000 results, so
# that is roughly a thousand posts a month for nothing.
#   https://apify.com/settings/integrations   (Personal API token)
#
# Without this the `linkedin_posts` source skips itself with a warning and every
# other source is unaffected.
#
# NOTE: only no-cookie actors are supported, deliberately. Actors that ask for
# your `li_at` session cookie put your own LinkedIn account at risk of being
# restricted, which is the exact thing this project is built to avoid.
APIFY_TOKEN=

# ---------------------------------------------------------------------------
# OPTIONAL — paths and overrides
# ---------------------------------------------------------------------------
# Defaults shown; uncomment to override.
# JOB_ALERTS_SETTINGS_FILE=config/settings.yaml
# JOB_ALERTS_SOURCES_FILE=config/sources.yaml
# JOB_ALERTS_DATABASE_PATH=data/jobs.db
# JOB_ALERTS_LOG_LEVEL=INFO
# JOB_ALERTS_LOG_FORMAT=text
